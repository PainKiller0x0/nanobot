[Unit]
Description=QQ Sidecar Rust Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/root/qq-sidecar-rs
Environment=QQ_SIDECAR_HOST=127.0.0.1
Environment=QQ_SIDECAR_PORT=8092
ExecStart=/usr/local/bin/qq-sidecar-rs
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
